# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Get this from Stripe Dashboard → Developers → Webhooks → your endpoint → signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Used to build Stripe success/cancel redirect URLs
NEXT_PUBLIC_SITE_URL=https://blessed-dressed.vercel.app

# ─── Admin Auth ───────────────────────────────────────────────────────────────
# Password to access /admin — set something strong
ADMIN_PASSWORD=change-me-before-launch

# ─── Vercel Blob Storage ──────────────────────────────────────────────────────
# Auto-added when you connect a Blob Store in the Vercel dashboard.
# For local dev you can omit this — the app falls back to local filesystem.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── Supabase (optional — currently not used) ─────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ─── Email Notifications (Resend) ─────────────────────────────────────────────
# Sign up free at https://resend.com — 100 emails/day, 3,000/month at no cost.
# 1. Create an API key at https://resend.com/api-keys
# 2. For testing use RESEND_FROM=onboarding@resend.dev (no domain needed)
# 3. For production verify your domain at https://resend.com/domains
RESEND_API_KEY=re_...
ADMIN_EMAIL=chasestanley91@gmail.com
RESEND_FROM=onboarding@resend.dev
